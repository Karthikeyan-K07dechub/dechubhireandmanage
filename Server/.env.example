PORT=4000
NODE_ENV=development
PAYMENT_PROVIDER=dummy

CLIENT_URL=http://localhost:3000
MONGODB_URI=mongodb://127.0.0.1:27017/dechub

JWT_SECRET=replace-with-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-at-least-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Keep these for future production Stripe rollout.
# They can stay empty while PAYMENT_PROVIDER=dummy.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=no-reply@example.com

DECHUB_ADMIN_EMAILS=admin@dechub.com
DECHUB_ADMIN_PASSWORD=Admin@1234

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
